# ================================================================
# .env.example — copie para .env e preencha com seus dados reais
# cp .env.example .env
# ================================================================

# Chave secreta do Flask (gere uma nova com o comando abaixo):
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-super-secreta-aqui

# ─────────────────────────────────────────
# Banco de dados (usado localmente)
# ─────────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:SENHA_DO_BANCO@localhost/lenspro

# Senha do root do MySQL (usada pelo docker-compose para subir o container)
MYSQL_ROOT_PASSWORD=SENHA_DO_BANCO

# ─────────────────────────────────────────
# Configurações de e-mail (opcional)
# Necessário apenas para recuperação de senha por e-mail
# ─────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=senha-de-app-do-google
